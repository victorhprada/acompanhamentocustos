# Production Environment Variables
# Copy this file to .env and fill in the real values

# ── Backend (.env) ───────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.your_ref:your_password@aws-0-region.pooler.supabase.com:6543/postgres
SECRET_KEY=change-me-to-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
API_V1_STR=/api/v1
ALLOWED_ORIGINS=https://acompanhamentodecustos.vercel.app

# ── Frontend (.env) ──────────────────────────────────────
VITE_API_BASE_URL=https://your-api-domain.com/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── GitHub Secrets (Settings → Secrets) ──────────────────
# SUPABASE_URL         → Same as backend SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY → Same as backend
# SUPABASE_ANON_KEY    → Same as frontend VITE_SUPABASE_ANON_KEY
